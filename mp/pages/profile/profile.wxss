.page { display: flex; flex-direction: column; background: var(--sl-bgDeep); }

.cover {
  height: 580rpx;
  position: relative;
  color: #fff;
  flex-shrink: 0;
  overflow: hidden;
}
.cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.6) 100%);
}
.top {
  position: absolute;
  top: 88rpx; left: 0; right: 0;
  padding: 0 24rpx;
  display: flex;
  justify-content: space-between;
  z-index: 3;
}
.ic-btn {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  backdrop-filter: blur(8px);
}
.cover-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 160rpx;
  color: rgba(255,255,255,0.4);
  z-index: 2;
}
.info {
  position: absolute;
  bottom: 32rpx; left: 32rpx; right: 32rpx;
  z-index: 3;
}
.name-row { display: flex; align-items: baseline; }
.name { font-size: 48rpx; font-weight: 800; color: #fff; }
.meta { font-size: 22rpx; margin-top: 6rpx; color: rgba(255,255,255,0.85); }
.sign { font-size: 26rpx; margin-top: 14rpx; color: rgba(255,255,255,0.95); }

.content { flex: 1; background: var(--sl-bgDeep); position: relative; z-index: 4; margin-top: -32rpx; border-radius: 32rpx 32rpx 0 0; padding-top: 16rpx; }

.section {
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
}
.sec-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--sl-text1);
  margin-bottom: 20rpx;
}
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.info-grid .it { display: flex; flex-direction: column; gap: 4rpx; }
.info-grid .it .k { font-size: 20rpx; }
.info-grid .it .v { font-size: 26rpx; color: var(--sl-text1); font-weight: 500; }

.tags { display: flex; flex-wrap: wrap; }

.album {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
}
.album .photo { aspect-ratio: 1; border-radius: 12rpx; }
.photo.p1 { background: linear-gradient(135deg, #ff8ab0, #7a9eff); }
.photo.p2 { background: linear-gradient(135deg, #a8c4ff, #5eead4); }
.photo.p3 { background: linear-gradient(135deg, #ffd966, #ff9a3c); }
.photo.p4 { background: linear-gradient(135deg, #ff5c8a, #ffd966); }
.photo.p5 { background: linear-gradient(135deg, #5eead4, #a8c4ff); }
.photo.p6 { background: linear-gradient(135deg, #ff8ad4, #a18cff); }

.cta {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--sl-bgCard);
  display: flex;
  gap: 12rpx;
  box-shadow: 0 -8rpx 24rpx rgba(0,0,0,0.4);
  z-index: 10;
}
.cta .b {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  gap: 6rpx;
}
.cta .b.b-gift { background: var(--sl-vipGrad); color: #3a2a00; }
.cta .b.b-fav { background: var(--sl-overlayCard); border: 1rpx solid var(--sl-border1); color: var(--sl-brand1); }
.cta .b.b-chat {
  background: var(--sl-brandGrad);
  color: #fff;
  box-shadow: var(--sl-shadowBtn);
  flex: 2;
}
