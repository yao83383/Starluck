<view class="page" style="{{themeStyle}}">
  <view class="cover av-{{user.av}}" style="padding-top:{{statusBarHeight}}px;">
    <view class="cover-mask"></view>
    <view class="top">
      <view class="ic-btn" bindtap="back">‹</view>
      <view class="ic-btn">⋯</view>
    </view>
    <view class="cover-center">✨</view>
    <view class="info">
      <view class="name-row">
        <text class="name">{{user.name}}</text>
        <text wx:if="{{user.vip}}" class="sl-tag vip" style="margin-left:10rpx;font-size:18rpx">VIP</text>
      </view>
      <view class="meta">{{user.age}}岁 · {{user.city}} · {{user.dist}}</view>
      <view class="sign">{{user.sign}}</view>
    </view>
  </view>

  <scroll-view class="content" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="section">
      <view class="sec-title">基本信息</view>
      <view class="info-grid">
        <view class="it"><view class="k text-3">身高</view><view class="v">{{user.height}}cm</view></view>
        <view class="it"><view class="k text-3">体重</view><view class="v">{{user.weight}}kg</view></view>
        <view class="it"><view class="k text-3">职业</view><view class="v">{{user.job}}</view></view>
        <view class="it"><view class="k text-3">学历</view><view class="v">{{user.edu}}</view></view>
        <view class="it"><view class="k text-3">家乡</view><view class="v">{{user.home}}</view></view>
        <view class="it"><view class="k text-3">情感</view><view class="v">{{user.love}}</view></view>
      </view>
    </view>

    <view class="section">
      <view class="sec-title">兴趣爱好</view>
      <view class="tags">
        <view class="sl-tag" wx:for="{{user.tags}}" wx:key="*this" style="margin-right:10rpx;margin-bottom:8rpx;">{{item}}</view>
      </view>
    </view>

    <view class="section">
      <view class="sec-title">相册</view>
      <view class="album">
        <view class="photo p1"></view>
        <view class="photo p2"></view>
        <view class="photo p3"></view>
        <view class="photo p4"></view>
        <view class="photo p5"></view>
        <view class="photo p6"></view>
      </view>
    </view>

    <view style="height:200rpx;"></view>
  </scroll-view>

  <view class="cta">
    <view class="b b-gift" bindtap="gift">🎁 送星愿</view>
    <view class="b b-fav" bindtap="fav">⭐ 点亮</view>
    <view class="b b-chat" bindtap="chat">💬 发出星语</view>
  </view>
</view>
