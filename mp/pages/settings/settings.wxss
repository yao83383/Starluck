.page { display: flex; flex-direction: column; }

.status-bar { flex-shrink: 0; position: relative; z-index: 5; }
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
  z-index: 5;
}
.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--sl-text1);
}
.nav-bar .title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--sl-text1);
}
.nav-bar .right { width: 64rpx; }

.body { flex: 1; position: relative; z-index: 2; }

.section-title {
  font-size: 22rpx;
  color: var(--sl-text3);
  padding: 24rpx 32rpx 12rpx;
  text-transform: none;
  letter-spacing: 1rpx;
}

.settings-group {
  margin: 0 24rpx;
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  border-radius: 24rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--sl-border1);
}
.settings-item:last-child { border-bottom: none; }
.settings-item .lbl { font-size: 28rpx; color: var(--sl-text1); }
.settings-item .val { font-size: 24rpx; }
.settings-item .arr { font-size: 36rpx; }

.sw {
  width: 84rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}
.sw.on { background: var(--sl-brand1); }
.sw::after {
  content: "";
  position: absolute;
  top: 4rpx; left: 4rpx;
  width: 40rpx; height: 40rpx;
  background: #fff;
  border-radius: 50%;
  transition: transform 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3);
}
.sw.on::after { transform: translateX(36rpx); }

/* ============ 主题选择器 ============ */
.theme-picker {
  display: flex;
  gap: 12rpx;
  padding: 24rpx;
}
.theme-mini {
  flex: 1;
  background: var(--sl-overlayCard);
  border: 2rpx solid var(--sl-border1);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  transition: transform 0.15s ease;
}
.theme-mini:active { transform: scale(0.96); }
.theme-mini.active {
  border-color: var(--sl-vipGold);
  background: rgba(255,217,102,0.08);
  box-shadow: 0 0 0 3rpx rgba(255,217,102,0.15);
}

.tm-color {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
}
.tm-color.tm-bg {
  width: 40rpx;
  height: 40rpx;
  margin-top: -28rpx;
  border: 2rpx solid var(--sl-bgCard);
}

.tm-name {
  font-size: 22rpx;
  color: var(--sl-text1);
  font-weight: 600;
}

.tm-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 30rpx;
  height: 30rpx;
  background: var(--sl-vipGold);
  color: #3a2a00;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
}

.theme-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-top: 1rpx solid var(--sl-border1);
  font-size: 24rpx;
  color: var(--sl-brand1);
  font-weight: 600;
  gap: 4rpx;
}
.theme-more .arr { font-size: 32rpx; }

/* ============ 退出 / 注销 ============ */
.logout {
  margin: 48rpx 24rpx 12rpx;
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  padding: 28rpx;
  text-align: center;
  border-radius: 24rpx;
  color: var(--sl-danger);
  font-size: 28rpx;
  font-weight: 600;
}
.delete-acc {
  text-align: center;
  padding: 20rpx;
  font-size: 22rpx;
}
