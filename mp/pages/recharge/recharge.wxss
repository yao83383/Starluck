.page { display: flex; flex-direction: column; }

.status-bar { flex-shrink: 0; position: relative; z-index: 5; }
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
  z-index: 5;
}
.nav-bar .back {
  width: 64rpx; height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--sl-text1);
}
.nav-bar .title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 700; color: var(--sl-text1); }
.nav-bar .right { font-size: 26rpx; padding-right: 16rpx; }

.body { flex: 1; position: relative; z-index: 2; }

.balance {
  text-align: center;
  padding: 48rpx 32rpx 24rpx;
}
.balance .lbl { font-size: 22rpx; }
.balance .num { font-size: 64rpx; font-weight: 800; margin-top: 12rpx; }

.bonus-banner {
  margin: 0 32rpx 24rpx;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, rgba(255,217,102,0.18), rgba(255,154,60,0.05));
  border: 1rpx solid rgba(255,217,102,0.35);
  border-radius: 20rpx;
  color: var(--sl-vipGold);
  font-size: 24rpx;
  font-weight: 600;
}

.pkg-grid {
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.pkg-card {
  background: var(--sl-bgCard);
  border: 2rpx solid var(--sl-border1);
  border-radius: 20rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  position: relative;
}
.pkg-card.on {
  border-color: var(--sl-vipGold);
  background: rgba(255,217,102,0.1);
}
.pkg-card .hot-tag {
  position: absolute;
  top: -14rpx; left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff5c8a, #ff8ab0);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}
.pkg-card .d {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--sl-vipGold);
}
.pkg-card .bn { font-size: 18rpx; margin-top: 4rpx; }
.pkg-card .p {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 12rpx;
  color: var(--sl-text1);
}

.pay-section {
  margin: 32rpx 24rpx;
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  border-radius: 20rpx;
  padding: 24rpx;
}
.pay-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--sl-text1);
  margin-bottom: 16rpx;
}
.pay-method {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--sl-border1);
}
.pay-method:last-child { border-bottom: none; }
.pay-method .pi { font-size: 36rpx; }
.pay-method .pn { font-size: 28rpx; color: var(--sl-text1); }
.pay-method .pr {
  width: 32rpx; height: 32rpx;
  border: 2rpx solid var(--sl-text3);
  border-radius: 50%;
}
.pay-method.on .pr {
  background: var(--sl-vipGold);
  border-color: var(--sl-vipGold);
  position: relative;
}
.pay-method.on .pr::after {
  content: "✓";
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  color: #3a2a00;
  font-size: 20rpx;
  font-weight: 700;
}

.tip {
  padding: 0 32rpx;
  font-size: 20rpx;
  line-height: 1.6;
}

.bottom-bar {
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--sl-bgCard);
  border-top: 1rpx solid var(--sl-border1);
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 10;
}
