.page { min-height: 100vh; }

.status-bar { position: relative; z-index: 5; }

.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
  z-index: 5;
}
.nav-bar .back {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: var(--sl-text1);
}
.nav-bar .title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 700; color: var(--sl-text1);
}
.nav-bar .right { width: 64rpx; }

.form { padding: 48rpx 40rpx; position: relative; z-index: 2; }

.hint {
  text-align: center;
  margin-bottom: 48rpx;
}
.hint-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.hint-title { font-size: 28rpx; font-weight: 700; color: var(--sl-text1); margin-bottom: 8rpx; }
.hint-desc { font-size: 22rpx; }

.field {
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}
.field-label {
  font-size: 22rpx;
  color: var(--sl-text3);
  margin-bottom: 8rpx;
}
.field-input {
  font-size: 30rpx;
  color: var(--sl-text1);
  width: 100%;
}
.ph { color: var(--sl-text3); }
