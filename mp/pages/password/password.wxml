<view class="page page-bg-radial" style="{{themeStyle}}">
  <starfield density="light"></starfield>

  <view class="status-bar" style="height:{{statusBarHeight}}px;"></view>

  <view class="nav-bar">
    <view class="back" bindtap="back">‹</view>
    <view class="title">设置登录密码</view>
    <view class="right"></view>
  </view>

  <view class="form">
    <view class="hint">
      <view class="hint-icon">🔐</view>
      <view class="hint-title">设置密码后可使用密码登录</view>
      <view class="hint-desc text-2">不用每次都收验证码</view>
    </view>

    <view class="field">
      <view class="field-label">新密码</view>
      <input
        class="field-input"
        type="text"
        password="{{true}}"
        placeholder="至少6位"
        placeholder-class="ph"
        value="{{newPwd}}"
        bindinput="onNewPwd"
        adjust-position="{{false}}"
      />
    </view>

    <view class="field">
      <view class="field-label">旧密码</view>
      <input
        class="field-input"
        type="text"
        password="{{true}}"
        placeholder="首次设置可不填"
        placeholder-class="ph"
        value="{{oldPwd}}"
        bindinput="onOldPwd"
        adjust-position="{{false}}"
      />
    </view>

    <sl-button type="primary" block bindtap="doSetPassword" loading="{{loading}}" disabled="{{loading}}">
      {{loading?'设置中...':'确认设置'}}
    </sl-button>
  </view>
</view>
