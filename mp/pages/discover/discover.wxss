.page { display: flex; flex-direction: column; }

.status-bar { flex-shrink: 0; }

.page-top {
  padding: 16rpx 32rpx 20rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}
.page-top .sub { font-size: 22rpx; font-style: italic; }

.tabs {
  white-space: nowrap;
  padding: 12rpx 32rpx 16rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}
.tabs .tab {
  display: inline-block;
  font-size: 28rpx;
  color: var(--sl-text3);
  font-weight: 500;
  padding: 8rpx 0;
  margin-right: 36rpx;
  position: relative;
}
.tabs .tab.on {
  color: var(--sl-text1);
  font-weight: 700;
  font-size: 32rpx;
}
.tabs .tab.on::after {
  content: "";
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--sl-brandGrad);
}

.filter {
  white-space: nowrap;
  padding: 0 32rpx 16rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}
.filter .chip {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: var(--sl-overlayCard);
  border: 1rpx solid var(--sl-border1);
  color: var(--sl-text2);
  font-size: 22rpx;
  border-radius: 28rpx;
  margin-right: 12rpx;
}
.filter .chip.on {
  background: var(--sl-brand1);
  color: #fff;
  border-color: var(--sl-brand1);
  font-weight: 600;
}

.grid-wrap { flex: 1; position: relative; z-index: 2; }

.user-grid {
  padding: 12rpx 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.user-card {
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--sl-shadowCard);
  transition: transform 0.2s ease;
}
.user-card.hover { transform: scale(0.97); }

.user-card .cover {
  width: 100%;
  aspect-ratio: 1/1.15;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.user-card .flags {
  position: absolute;
  top: 12rpx; left: 12rpx;
  display: flex;
  gap: 6rpx;
  z-index: 2;
}
.user-card .flag {
  padding: 4rpx 10rpx;
  font-size: 18rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 12rpx;
  backdrop-filter: blur(8px);
}
.user-card .flag.online { background: var(--sl-success); color: #003a2f; font-weight: 700; }
.user-card .flag.vip { background: var(--sl-vipGrad); color: #3a2a00; font-weight: 700; }
.user-card .flag.fake { background: linear-gradient(135deg, #ff8ad4, #a18cff); color: #fff; font-weight: 600; }

.user-card .cover-emoji {
  position: relative;
  z-index: 1;
  font-size: 80rpx;
  color: rgba(255,255,255,0.85);
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.3);
}

.user-card .info { padding: 14rpx 16rpx 18rpx; }
.user-card .info .name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--sl-text1);
  display: flex;
  align-items: center;
}
.gender-tag {
  font-size: 26rpx;
  margin-right: 6rpx;
  font-weight: 700;
}
.gender-tag.male   { color: #7ab5ff; }
.gender-tag.female { color: #ff8ad4; }
.user-card .info .meta { font-size: 20rpx; margin-top: 4rpx; }
.user-card .info .tags {
  display: flex;
  margin-top: 10rpx;
  gap: 6rpx;
  flex-wrap: wrap;
}
