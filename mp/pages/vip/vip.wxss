.page { display: flex; flex-direction: column; }

.status-bar { flex-shrink: 0; position: relative; z-index: 5; }
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
  z-index: 5;
}
.nav-bar .back {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: var(--sl-text1);
}
.nav-bar .title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 700; color: var(--sl-text1); }
.nav-bar .right { width: 64rpx; }

.body { flex: 1; position: relative; z-index: 2; }

.hero {
  text-align: center;
  padding: 40rpx 32rpx 24rpx;
}
.crown { font-size: 100rpx; line-height: 1; }
.hero-title { font-size: 44rpx; font-weight: 800; color: var(--sl-vipGold); margin-top: 16rpx; }
.hero-sub { font-size: 22rpx; margin-top: 10rpx; }

.status-card {
  margin: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(255,217,102,0.15), rgba(255,154,60,0.05));
  border: 1rpx solid rgba(255,217,102,0.3);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.sc-icon { font-size: 56rpx; }
.t1 { font-size: 28rpx; font-weight: 700; }
.t2 { font-size: 22rpx; margin-top: 4rpx; }

.plans {
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}
.plan {
  background: var(--sl-bgCard);
  border: 2rpx solid var(--sl-border1);
  border-radius: 20rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  position: relative;
}
.plan.on { border-color: var(--sl-vipGold); background: rgba(255,217,102,0.1); }
.plan .hot-tag {
  position: absolute;
  top: -14rpx; left: 50%;
  transform: translateX(-50%);
  background: #ff5c8a;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}
.plan .pn { font-size: 26rpx; color: var(--sl-text1); }
.plan .pp { font-size: 44rpx; font-weight: 800; color: var(--sl-vipGold); margin-top: 8rpx; }
.plan .po { font-size: 20rpx; text-decoration: line-through; margin-top: 4rpx; }
.plan .pd { font-size: 20rpx; margin-top: 4rpx; }

.rights-card {
  margin: 32rpx 24rpx;
  padding: 28rpx 24rpx;
  background: var(--sl-bgCard);
  border: 1rpx solid var(--sl-border1);
  border-radius: 20rpx;
}
.rc-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--sl-vipGold);
  margin-bottom: 24rpx;
}
.rights-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}
.vr { text-align: center; }
.vr .ic {
  width: 84rpx; height: 84rpx;
  background: var(--sl-vipGrad);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto;
  color: #3a2a00;
}
.vr .nm { font-size: 20rpx; margin-top: 10rpx; }

.agree { text-align: center; font-size: 20rpx; padding: 0 32rpx 24rpx; }

.bottom-bar {
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(8,10,24,0.92);
  border-top: 1rpx solid var(--sl-border1);
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 10;
  backdrop-filter: blur(20px);
}
