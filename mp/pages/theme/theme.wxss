.page { display: flex; flex-direction: column; }

.status-bar { flex-shrink: 0; position: relative; z-index: 5; }

.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  position: relative;
  z-index: 5;
}
.nav-bar .back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--sl-text1);
}
.nav-bar .title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--sl-text1);
}
.nav-bar .right { width: 64rpx; }

.hero {
  text-align: center;
  padding: 20rpx 32rpx 32rpx;
  position: relative;
  z-index: 2;
}
.hero-emoji { font-size: 80rpx; }
.hero-title { margin-top: 16rpx; }
.hero-sub { font-size: 22rpx; margin-top: 8rpx; font-style: italic; }

.cards-wrap { flex: 1; position: relative; z-index: 2; }

.theme-card {
  margin: 24rpx;
  background: var(--sl-bgCard);
  border: 2rpx solid var(--sl-border1);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--sl-shadowCard);
  transition: transform 0.2s;
}
.theme-card.hover { transform: scale(0.985); }
.theme-card.current {
  border-color: var(--sl-vipGold);
  box-shadow: 0 0 0 4rpx rgba(255,217,102,0.18), var(--sl-shadowCard);
}

.preview {
  height: 340rpx;
  position: relative;
  overflow: hidden;
}

.preview-star {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    radial-gradient(3rpx 3rpx at 18% 22%, #ffffff, transparent),
    radial-gradient(2rpx 2rpx at 60% 70%, #ffffff, transparent),
    radial-gradient(4rpx 4rpx at 80% 30%, #e0c8ff, transparent),
    radial-gradient(2rpx 2rpx at 40% 80%, #ffffff, transparent),
    radial-gradient(3rpx 3rpx at 88% 60%, #ffd6f5, transparent);
  background-size: 480rpx 480rpx;
  opacity: 0.7;
}

.preview .badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ffd966, #ff9a3c);
  color: #3a2a00;
  padding: 6rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 14rpx rgba(255,217,102,0.4);
  z-index: 3;
}

.mini-phone {
  position: absolute;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 290rpx;
  border-radius: 36rpx;
  background: #000;
  padding: 8rpx;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.5);
  overflow: hidden;
  z-index: 2;
}
.mini-screen {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.mini-logo { font-size: 40rpx; }
.mini-brand { font-size: 32rpx; font-weight: 800; margin-top: 6rpx; }
.mini-slogan { font-size: 16rpx; margin-top: 4rpx; }
.mini-btn {
  margin-top: 18rpx;
  padding: 10rpx 0;
  width: 80%;
  text-align: center;
  border-radius: 20rpx;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
}
.mini-row {
  display: flex;
  gap: 8rpx;
  margin-top: 14rpx;
  width: 80%;
}
.mini-dot {
  flex: 1;
  height: 28rpx;
  border-radius: 8rpx;
}

.info { padding: 24rpx; }
.info-row { display: flex; align-items: baseline; gap: 12rpx; }
.info-row .name { font-size: 32rpx; font-weight: 800; color: var(--sl-text1); }
.info-row .en { font-size: 20rpx; letter-spacing: 1rpx; }
.info .desc { font-size: 24rpx; margin-top: 8rpx; }

.swatches {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}
.swatches .sw {
  flex: 1;
  height: 40rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.footer { margin-top: 20rpx; }
.btn-apply {
  text-align: center;
  padding: 20rpx;
  background: var(--sl-brandGrad);
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: var(--sl-shadowBtn);
}
.btn-current {
  text-align: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #ffd966, #ff9a3c);
  color: #3a2a00;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.tip {
  margin: 12rpx 48rpx;
  padding: 20rpx;
  background: var(--sl-overlayCard);
  border-radius: 16rpx;
  font-size: 22rpx;
  line-height: 1.7;
  text-align: center;
}
